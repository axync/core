# Axync Backend Environment Variables

# Server Configuration
RUST_LOG=info
PORT=8080

# Storage Configuration
STORAGE_PATH=./data

# Block Production
BLOCK_INTERVAL_SEC=1
MAX_QUEUE_SIZE=10000
MAX_TXS_PER_BLOCK=100

# Prover Configuration
USE_PLACEHOLDER_PROVER=true
GROTH16_KEYS_DIR=./crates/prover/keys
FORCE_REGENERATE_KEYS=false

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Watcher Configuration - Testnet Mode (Ethereum Sepolia + Base Sepolia)
# Ethereum Sepolia Testnet
ETHEREUM_CHAIN_ID=11155111
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_DEPOSIT_CONTRACT=0xC0659E7a7b4E81AFe607A7aECd57A7E8E23Ba164
ETHEREUM_ESCROW_CONTRACT=0x58b91CCB7F4DC0f749573f55f13f8892A5189f53
ETHEREUM_START_BLOCK=10512000
ETHEREUM_REQUIRED_CONFIRMATIONS=2

# Base Sepolia Testnet
BASE_CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org
BASE_DEPOSIT_CONTRACT=0xE047A68aaB75C479aF21bA34F5fE931c13ed770a
BASE_ESCROW_CONTRACT=0xa0654945B0d571c78Bf3D1cE4d3cfF45B76FCF99
BASE_START_BLOCK=0
BASE_REQUIRED_CONFIRMATIONS=2

# Common Watcher Settings
POLL_INTERVAL_SECONDS=3
RPC_TIMEOUT_SECONDS=30
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1
REORG_SAFETY_BLOCKS=10

# For Local Development (Hardhat) - uncomment and comment out testnet config above
# CHAIN_ID=31337
# RPC_URL=http://localhost:8545
# DEPOSIT_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# WITHDRAWAL_CONTRACT_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
# REQUIRED_CONFIRMATIONS=0
